{
  "dataset": "data/processed/master_dataset.csv",
  "random_seed": 42,
  "n_rows": 2428,
  "n_features_used": 15,
  "features_used": [
    "knee_flexion_at_bottom",
    "knee_flexion_range",
    "trunk_lean_at_bottom",
    "trunk_lean_mean",
    "trunk_lean_max",
    "trunk_lean_range",
    "trunk_lean_at_end",
    "descent_ascent_ratio",
    "descent_time_s",
    "ascent_time_s",
    "knee_vel_max_descent",
    "knee_vel_max_ascent",
    "knee_jerk_max",
    "knee_jerk_rms",
    "normalized_jerk_cost"
  ],
  "pca_variance_threshold": 0.95,
  "pca_anomaly_sigma": 2.0,
  "dtw_max_k": 6,
  "dtw_n_init": 10,
  "arm_min_support": 0.03,
  "arm_min_confidence": 0.6,
  "arm_min_lift": 1.05,
  "arm_exclude_flags": [
    "shallow_squat",
    "ankle_restricted",
    "butt_wink"
