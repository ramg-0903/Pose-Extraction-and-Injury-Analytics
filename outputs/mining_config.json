  "rf_n_estimators": 200,
  "rf_cv_folds": 5,
  "rf_n_seeds": 10,
  "all_flags": [
    "shallow_squat",
    "excessive_lean",
    "asymmetric_depth",
    "ankle_restricted",
    "rushed_descent",
    "butt_wink",
    "high_jerk",
    "incomplete_depth",
    "unstable_return",
    "asymmetric_start"
  ],
  "extra_flag_defs": {
    "high_jerk": [
      "knee_jerk_rms",
      "gt",
      "p75"
    ],
    "incomplete_depth": [
      "knee_flexion_at_bottom",
      "gt",
      120.0
    ],
    "unstable_return": [
      "symmetry_knee_at_end",
      "gt",
      15.0
    ],
    "asymmetric_start": [
      "symmetry_knee_at_start",
      "gt",
      10.0
    ]
  }
